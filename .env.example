# ====================
# DeepSeek API 配置
# ====================
# 从 https://platform.deepseek.com/ 获取 API 密钥
DEEPSEEK_API_KEY=sk-your-api-key-here
MODEL_NAME=deepseek-chat  # 支持的模型：deepseek-chat, deepseek-coder

# ====================
# 嵌入模型配置（RAG使用）
# ====================
# 文本嵌入模型，用于向量化文档内容
EMBEDDING_MODEL=text-embedding-ada-002

# ====================
# 飞书应用配置（飞书集成需要）
# ====================
# 从 https://open.feishu.cn/ 创建应用获取
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# ====================
# 服务器配置
# ====================
USE_WEBHOOK=false          # true: Webhook模式, false: CLI模式
HOST=0.0.0.0              # 监听地址
PORT=5000                 # 监听端口

# ====================
# RAG 配置
# ====================
CHUNK_SIZE=500             # 文本分块大小（字符数）
CHUNK_OVERLAP=50           # 分块重叠大小（字符数）
SEARCH_RESULTS_COUNT=5     # 检索结果数量

# ====================
# 对话配置
# ====================
CONV_MAX_TURNS=10          # 最大对话轮次（每轮包含用户和助手各一条消息）
CONV_IDLE_TIMEOUT=1800     # 会话空闲超时（秒），30分钟无活动自动重置
CONV_MAX_SESSIONS=5000     # 内存模式下最大会话数

# ====================
# 安全配置
# ====================
DEDUP_TTL=60               # 消息去重TTL（秒），防止重复处理相同消息
DEDUP_MAX_MEMORY=2000      # 内存去重最大条目数

# ====================
# Redis 配置（可选，用于生产环境）
# ====================
# Redis用于分布式会话存储和消息去重，不配置则使用内存模式
REDIS_HOST=localhost       # Redis服务器地址
REDIS_PORT=6379           # Redis端口
REDIS_PASSWORD=           # Redis密码（如果没有密码则留空）
REDIS_DB=0                # Redis数据库编号